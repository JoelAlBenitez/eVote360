@model IEnumerable<eVote360.Core.Application.ViewModels.Users.UsersViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var hasData = Model != null && Model.Any();
    var count = Model?.Count() ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}


<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #e8f5e9; color: #2e7d32; padding: 12px; border-radius: 12px;">
            <i class="bi bi-people-fill" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Usuarios del Sistema</h1>
            <p class="page-header__subtitle">
                @count usuario@(count != 1 ? "s" : "") registrado@(count != 1 ? "s" : "")
            </p>
        </div>
    </div>
    <a asp-action="Create" class="btn-add">
        <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
        <span>Nuevo Usuario</span>
    </a>
</div>

@if (hasData)
{
    <div class="data-table-wrap d-none d-md-block">
        <table class="data-table" aria-label="Lista de usuarios">
            <thead>
                <tr>
                    <th scope="col">
                        <i class="bi bi-at" aria-hidden="true"></i>Usuario (Login)
                    </th>
                    <th scope="col">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>Nombre Completo
                    </th>
                    <th scope="col">
                        <i class="bi bi-envelope-fill" aria-hidden="true"></i>Correo
                    </th>
                    <th scope="col">
                        <i class="bi bi-shield-fill" aria-hidden="true"></i>Rol
                    </th>
                    <th scope="col">
                        <i class="bi bi-toggle-on" aria-hidden="true"></i>Estado
                    </th>
                    <th scope="col" class="text-center">
                        <i class="bi bi-gear-fill" aria-hidden="true"></i>Acciones
                    </th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                @foreach (var item in Model!)
                {
                    <tr>
                        <td class="data-table__name">@item.Name</td>
                        <td>@item.UserFirstName @item.UserLastName</td>
                        <td>
                            <a href="mailto:@item.UserEmail" class="text-decoration-none">@item.UserEmail</a>
                        </td>
                        <td>
                            @if (item.UserRole == eVote360.Core.Domain.Common.Enums.UserRole.Admin)
                            {
                                <span class="data-badge data-badge--active">
                                    <i class="bi bi-shield-lock-fill" aria-hidden="true"></i>
                                    Administrador
                                </span>
                            }
                            else
                            {
                                <span class="data-badge" style="background:#e3f2fd; color:#1565c0;">
                                    <i class="bi bi-person-badge-fill" aria-hidden="true"></i>
                                    Dirigente
                                </span>
                            }
                        </td>
                        <td>
                            <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                                <i class="bi @(item.State ? "bi-check-circle-fill" : "bi-x-circle-fill")" aria-hidden="true"></i>
                                @(item.State ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions justify-content-center">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn-table-action btn-table-action--edit"
                                   title="Editar"
                                   aria-label="Editar usuario @item.Name">
                                    <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                                </a>
                                <form asp-action="AlterState" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="state" value="@item.State.ToString().ToLower()" />
                                    <button type="submit"
                                            class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                            title="@(item.State ? "Desactivar" : "Activar")"
                                            aria-label="@(item.State ? "Desactivar" : "Activar") usuario @item.Name"
                                            onclick="return confirm('¿Está seguro que desea @(item.State ? "desactivar" : "activar") este usuario?');">
                                        <i class="bi @(item.State ? "bi-person-x-fill" : "bi-person-check-fill")" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-wrap" id="paginationWrap" aria-label="Paginación"></div>
    </div>

    <div class="ep-cards d-md-none" id="userCards" aria-label="Lista de usuarios">
        @foreach (var item in Model!)
        {
            <article class="ep-card">
                <div class="ep-card__header">
                    <span class="ep-card__name">@item.Name</span>
                    <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                        @(item.State ? "Activo" : "Inactivo")
                    </span>
                </div>
                <div class="ep-card__meta">
                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                    @item.UserFirstName @item.UserLastName
                </div>
                <div class="ep-card__meta">
                    <i class="bi bi-envelope-fill" aria-hidden="true"></i>
                    @item.UserEmail
                </div>
                <div class="ep-card__footer">
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn-table-action btn-table-action--edit"
                       title="Editar"
                       aria-label="Editar @item.Name">
                        <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                    </a>
                    <form asp-action="AlterState" asp-route-id="@item.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="state" value="@item.State.ToString().ToLower()" />
                        <button type="submit"
                                class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                title="@(item.State ? "Desactivar" : "Activar")"
                                onclick="return confirm('¿Desactivar/Activar este usuario?');">
                            <i class="bi @(item.State ? "bi-person-x-fill" : "bi-person-check-fill")" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </article>
        }
        <div class="pagination-wrap" id="paginationWrapMobile" aria-label="Paginación móvil"></div>
    </div>
}
else
{
    <div class="empty-state" role="status">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-people"></i>
        </div>
        <h2 class="empty-state__title">Sin usuarios registrados</h2>
        <p class="empty-state__desc">
            Aún no se han registrado usuarios en el sistema.
        </p>
        <a asp-action="Create" class="btn-primary-outline">
            <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
            Registrar Usuario
        </a>
    </div>
}

@section Scripts {
    <script src="~/js/admin-views.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            window.initTablePagination('usersTableBody', 'paginationWrap', 10);
            window.initCardPagination('userCards', 'paginationWrapMobile', 5, '.ep-card');
        });
    </script>
}
