@model IEnumerable<eVote360.Core.Application.ViewModels.Candidates.CandidateViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_LeaderLayout";
    ViewData["Title"] = "Candidatos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Candidatos</h2>
        <a asp-action="Create" class="btn btn-primary">Nuevo Candidato</a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Foto</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.PhotoUrl))
                                    {
                                        <img src="~/img/candidates/@item.PhotoUrl" alt="Foto de @item.Name" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <img src="~/img/evote360-logo.png" alt="Sin foto" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                </td>
                                <td>@item.Name</td>
                                <td>@item.LastName</td>
                                <td>
                                    @if (item.State)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-Id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                    <a asp-action="AlterState" asp-route-Id="@item.Id"
                                       class="btn btn-sm @(item.State ? "btn-danger" : "btn-success")">
                                        @(item.State ? "Desactivar" : "Activar")
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No hay candidatos registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
