@model eVote360.Core.Application.ViewModels.Candidates.CandidateViewModelEdit
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Editar Candidato";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Candidato</h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Edit" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Nombre</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label">Apellido</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.CurrentPhotoUrl))
                        {
                            <div class="mb-3 text-center">
                                <label class="form-label d-block">Foto Actual</label>
                                <img src="~/img/candidates/@Model.CurrentPhotoUrl" alt="Foto actual" class="img-thumbnail" style="height: 80px;" />
                            </div>
                        }

                        <div class="mb-4">
                            <label asp-for="PhotoFile" class="form-label">Nueva Foto (Opcional)</label>
                            <input type="file" asp-for="PhotoFile" class="form-control" accept="image/*" />
                            <span asp-validation-for="PhotoFile" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Volver</a>
                            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
