@model List<eVote360.Core.Application.ViewModels.Elector.Dashboard.ElectorElectionPositionViewModel>
@{
    ViewData["Title"] = "Panel de Votación";
}

<div class="row mb-4">
    <div class="col-12 text-center">
        <h2 class="fw-bold text-primary">Proceso de Selección</h2>
        <p class="text-muted">Seleccione cada posición para elegir a su candidato de preferencia.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var position in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card ev-card h-100 border-0 shadow-sm position-relative @(position.StateSelection ? "border-start border-success border-4" : "")">
                @if (position.StateSelection)
                {
                    <div class="position-absolute top-0 end-0 p-3">
                        <span class="badge bg-success rounded-pill shadow-sm">
                            <i class="bi bi-check-circle-fill me-1"></i> Seleccionado
                        </span>
                    </div>
                }
                
                <div class="card-body p-4 d-flex flex-column">
                    <div class="mb-3 d-flex align-items-center">
                        <div class="bg-primary-subtle p-3 rounded-4 me-3">
                            <i class="bi bi-box-seam-fill text-primary fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">@position.NameElectivePosition</h5>
                            <small class="text-muted">Boleta #@position.NumberPoliticalParty</small>
                        </div>
                    </div>
                    
                    <p class="text-muted small flex-grow-1">
                        Hay <strong>@position.NumberOfActualCandidactes</strong> candidatos disponibles para esta posición.
                    </p>
                    
                    <div class="mt-3">
                        @if (position.StateSelection)
                        {
                            <a asp-action="SelectPosition" asp-route-id="@position.IdElectivePosition" class="btn btn-outline-success w-100 rounded-pill fw-bold">
                                Cambiar Selección <i class="bi bi-pencil-square ms-1"></i>
                            </a>
                        }
                        else
                        {
                            <a asp-action="SelectPosition" asp-route-id="@position.IdElectivePosition" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">
                                Seleccionar <i class="bi bi-arrow-right-short fs-5 ms-1"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row mt-5">
    <div class="col-12 text-center">
        @{
            var allSelected = Model.All(p => p.StateSelection);
        }
        <div class="card ev-card bg-primary text-white border-0 p-4 shadow-lg rounded-5 overflow-hidden position-relative">
            <div class="card-body">
                <h4 class="fw-bold mb-3">¿Ha terminado su selección?</h4>
                <p class="mb-4 opacity-75">Revise cuidadosamente sus elecciones antes de confirmar su voto definitivo.</p>
                
                @if (allSelected)
                {
                    <a asp-action="ConfirmVote" class="btn btn-light btn-lg px-5 fw-bold rounded-pill shadow animate__animated animate__pulse animate__infinite">
                        Confirmar mi Voto <i class="bi bi-send-check-fill ms-2"></i>
                    </a>
                }
                else
                {
                    <button class="btn btn-light btn-lg px-5 fw-bold rounded-pill shadow opacity-50 cursor-not-allowed" disabled>
                        Faltan Selecciones <i class="bi bi-lock-fill ms-2"></i>
                    </button>
                    <div class="mt-3 small opacity-75 text-white">
                        <i class="bi bi-info-circle me-1"></i> Debe elegir una opción en todas las posiciones para poder finalizar.
                    </div>
                }
            </div>
            <div class="position-absolute top-0 end-0 bg-white opacity-10 rounded-circle" style="width: 200px; height: 200px; margin-top: -100px; margin-right: -100px;"></div>
        </div>
    </div>
</div>
