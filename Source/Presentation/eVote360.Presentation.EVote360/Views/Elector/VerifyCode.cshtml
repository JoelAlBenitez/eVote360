@model eVote360.Core.Application.ViewModels.Elector.Code.CodeVerificationViewModel
@{
    ViewData["Title"] = "Código de Seguridad";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="mb-4 text-center">
            <h2 class="h3 fw-bold text-dark">Doble Factor de Seguridad</h2>
            <p class="text-muted">Hemos enviado un código de 6 dígitos a su correo electrónico registrado.</p>
        </div>

        <div class="card ev-card border-0 shadow-lg overflow-hidden">
            <div class="bg-primary py-3 px-4">
                <h5 class="text-white mb-0 text-center"><i class="bi bi-envelope-check-fill me-2"></i>Verifique su Correo</h5>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="VerifyCode" method="post">
                    <div class="mb-5 text-center">
                        <label asp-for="CodeVerification" class="form-label fw-bold d-block mb-3">Ingrese el Código</label>
                        <div class="d-flex justify-content-center gap-2" id="otp-inputs">
                            <input asp-for="CodeVerification" type="number" class="form-control text-center fs-2 fw-bold border-2 rounded-4 shadow-sm" style="max-width: 250px; letter-spacing: 0.5rem;" maxlength="6" placeholder="000000" autofocus />
                        </div>
                        <span asp-validation-for="CodeVerification" class="text-danger small mt-2 d-block"></span>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold rounded-pill py-3 shadow">
                            Validar y Acceder <i class="bi bi-shield-lock ms-2"></i>
                        </button>
                        <button type="button" class="btn btn-link text-decoration-none fw-medium">
                            ¿No recibió el código? Reenviar en 05:00
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-4 p-3 bg-warning-subtle rounded-4 text-center border border-warning-subtle">
            <small class="text-warning-emphasis fw-medium">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> 
                El código es válido por 10 minutos. No comparta este código con nadie.
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
