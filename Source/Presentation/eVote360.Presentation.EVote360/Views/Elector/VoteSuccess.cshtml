@{
    ViewData["Title"] = "¡Voto Registrado!";
}

<div class="row justify-content-center animate__animated animate__zoomIn">
    <div class="col-md-8 col-lg-6">
        <div class="card ev-card border-0 shadow-lg text-center p-5 rounded-5 mt-5 overflow-hidden">
            <div class="card-body py-5 position-relative">
                <div class="success-checkmark mb-4">
                    <div class="check-icon">
                        <span class="icon-line line-tip"></span>
                        <span class="icon-line line-long"></span>
                        <div class="icon-circle"></div>
                        <div class="icon-fix"></div>
                    </div>
                </div>
                
                <h1 class="display-6 fw-bold text-dark mb-3">¡Voto Exitoso!</h1>
                <p class="text-muted lead mb-4">Su participación ha sido registrada correctamente. Un resumen de su votación ha sido enviado a su correo electrónico.</p>
                
                <div class="bg-light p-4 rounded-4 mb-4 border border-success-subtle">
                    <h6 class="fw-bold text-success mb-2"><i class="bi bi-shield-fill-check me-2"></i>Compromiso Ciudadano</h6>
                    <p class="small text-muted mb-0">Gracias por formar parte de este proceso democrático. Su identidad y elección están protegidas por criptografía de grado militar.</p>
                </div>

                <div class="d-grid">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill fw-bold shadow py-3">
                        Finalizar y Cerrar Sesión <i class="bi bi-box-arrow-right ms-2"></i>
                    </a>
                </div>

                <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden" style="z-index: -1;">
                    <div class="bg-primary opacity-5 rounded-circle position-absolute" style="width: 300px; height: 300px; top: -150px; left: -150px;"></div>
                    <div class="bg-success opacity-5 rounded-circle position-absolute" style="width: 200px; height: 200px; bottom: -100px; right: -100px;"></div>
                </div>
            </div>
        </div>
        <p class="text-center mt-4 text-muted small">
            eVote360 - Innovación al servicio de la democracia
        </p>
    </div>
</div>

@section Scripts {
    <style>
        .success-checkmark {
            width: 80px;
            height: 80px;
            margin: 0 auto;
        }
        .check-icon {
            width: 80px;
            height: 80px;
            position: relative;
            border-radius: 50%;
            box-sizing: content-box;
            border: 4px solid #4CAF50;
        }
        .check-icon::before {
            top: 3px;
            left: -2px;
            width: 30px;
            transform-origin: 100% 50%;
            border-radius: 100px 0 0 100px;
        }
        .check-icon::after {
            top: 0;
            left: 30px;
            width: 60px;
            transform-origin: 0 50%;
            border-radius: 0 100px 100px 0;
            animation: rotate-circle 4.25s ease-in;
        }
        .icon-line {
            height: 5px;
            background-color: #4CAF50;
            display: block;
            border-radius: 2px;
            position: absolute;
            z-index: 10;
        }
        .line-tip {
            top: 46px;
            left: 14px;
            width: 25px;
            transform: rotate(45deg);
            animation: icon-line-tip 0.75s;
        }
        .line-long {
            top: 38px;
            right: 8px;
            width: 47px;
            transform: rotate(-45deg);
            animation: icon-line-long 0.75s;
        }
        .icon-circle {
            top: -4px;
            left: -4px;
            z-index: 10;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 4px solid rgba(76, 175, 80, .5);
            box-sizing: content-box;
            position: absolute;
        }
        .icon-fix {
            top: 8px;
            width: 5px;
            left: 26px;
            z-index: 1;
            height: 85px;
            position: absolute;
            transform: rotate(-45deg);
            background-color: #FFFFFF;
        }
        @@keyframes icon-line-tip {
            0% { width: 0; left: 1px; top: 19px; }
            54% { width: 0; left: 1px; top: 19px; }
            70% { width: 50px; left: -8px; top: 37px; }
            84% { width: 17px; left: 21px; top: 48px; }
            100% { width: 25px; left: 14px; top: 46px; }
        }
        @@keyframes icon-line-long {
            0% { width: 0; right: 46px; top: 54px; }
            65% { width: 0; right: 46px; top: 54px; }
            84% { width: 55px; right: 0px; top: 35px; }
            100% { width: 47px; right: 8px; top: 38px; }
        }
    </style>
}
