@model eVote360.Core.Application.ViewModels.PoliticalAlliances.CreateAllianceViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Nueva Solicitud de Alianza";
}

<div class="container-fluid px-4 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h3 class="fw-light text-secondary mb-4 text-center">Nueva Solicitud de Alianza</h3>
                    
                    <form method="post" asp-action="Create">
                        <div class="mb-4">
                            <label asp-for="ReceivingPartyId" class="form-label text-muted">Partido Político Destino</label>
                            <select asp-for="ReceivingPartyId" class="form-select rounded-pill">
                                <option value="">-- Seleccione un partido --</option>
                                @foreach (var party in Model.AvailableParties)
                                {
                                    <option value="@party.Value">@party.Text</option>
                                }
                            </select>
                            <span asp-validation-for="ReceivingPartyId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-center gap-3 mt-5">
                            <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Enviar Solicitud</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
