@using eVote360.Core.Application.ViewModels.Election
@using eVote360.Core.Domain.Common.Enums
@model List<ElectionViewModel>
@{
    ViewData["Title"] = "Gestión de Elecciones";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var hasData = Model != null && Model.Any();
    var count = Model?.Count ?? 0;
    var hasActiveElection = Model?.Any(e => e.ElectionState == ElectionState.Activa) ?? false;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #e8f5e9; color: #2e7d32; padding: 12px; border-radius: 12px;">
            <i class="bi bi-calendar-event-fill" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Procesos Electorales</h1>
            <p class="page-header__subtitle">
                @count proceso@(count != 1 ? "s" : "") registrado@(count != 1 ? "s" : "") en el sistema
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        @if (!hasActiveElection)
        {
            <a asp-action="Create" class="btn-add">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                <span>Nueva Elección</span>
            </a>
        }
        else
        {
            <span class="btn-add" style="opacity:.5; cursor:not-allowed; pointer-events:none;" title="Existe una elección activa">
                <i class="bi bi-lock-fill" aria-hidden="true"></i>
                <span>Nueva Elección</span>
            </span>
        }
    </div>
</div>

<div class="filters-bar">
    <div class="filters-bar__quick">
        <a asp-action="Index" class="btn-filter-outline">
            <i class="bi bi-list-ul" aria-hidden="true"></i>
            Todas
        </a>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-@(TempData["TypeAlert"] ?? "info") alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (hasData)
{
    <div class="data-table-wrap">
        <table class="data-table" aria-label="Lista de procesos electorales">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col"><i class="bi bi-type" aria-hidden="true"></i>Nombre de Elección</th>
                    <th scope="col"><i class="bi bi-calendar3" aria-hidden="true"></i>Fecha Programada</th>
                    <th scope="col"><i class="bi bi-info-circle" aria-hidden="true"></i>Etapa</th>
                    <th scope="col" class="text-center"><i class="bi bi-gear-fill" aria-hidden="true"></i>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model!.OrderBy(e => e.ElectionState == ElectionState.Activa ? 0 : e.ElectionState == ElectionState.Pendiente ? 1 : 2))
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="data-table__name">@item.Name</td>
                        <td>@item.ElectionDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                var (badgeClass, badgeIcon) = item.ElectionState switch
                                {
                                    ElectionState.Pendiente => ("badge bg-warning text-dark", "bi-hourglass-split"),
                                    ElectionState.Activa    => ("badge bg-success text-white", "bi-check-circle-fill"),
                                    ElectionState.Finalizada => ("badge bg-secondary text-white", "bi-flag-fill"),
                                    _ => ("badge bg-light text-dark", "bi-question-circle")
                                };
                            }
                            <span class="@badgeClass">
                                <i class="bi @badgeIcon me-1" aria-hidden="true"></i>@item.ElectionState
                            </span>
                        </td>
                        <td>
                            <div class="table-actions justify-content-center">
                                @if (item.ElectionState == ElectionState.Pendiente)
                                {
                                    <a asp-action="Edit" asp-route-Id="@item.Id"
                                       class="btn-table-action btn-table-action--edit" title="Editar" aria-label="Editar @item.Name">
                                        <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="ConfirmActivate" asp-route-id="@item.Id"
                                       class="btn-table-action btn-table-action--activate" title="Activar elección" aria-label="Activar @item.Name">
                                        <i class="bi bi-play-circle-fill" aria-hidden="true"></i>
                                    </a>
                                }
                                else if (item.ElectionState == ElectionState.Activa)
                                {
                                    <a asp-action="ConfirmFinalize" asp-route-id="@item.Id"
                                       class="btn-table-action btn-table-action--deactivate" title="Finalizar elección" aria-label="Finalizar @item.Name">
                                        <i class="bi bi-stop-circle-fill" aria-hidden="true"></i>
                                    </a>
                                }
                                else if (item.ElectionState == ElectionState.Finalizada)
                                {
                                    <a asp-action="SelectYear"
                                       class="btn-table-action" style="background:#1976d2;color:#fff;" title="Ver resultados" aria-label="Resultados @item.Name">
                                        <i class="bi bi-bar-chart-fill" aria-hidden="true"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state" role="status">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-calendar-x"></i>
        </div>
        <h2 class="empty-state__title">No hay elecciones registradas</h2>
        <p class="empty-state__desc">Aún no se han configurado procesos electorales en el sistema.</p>
        <a asp-action="Create" class="btn-primary-outline">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            Programar Primera Elección
        </a>
    </div>
}
