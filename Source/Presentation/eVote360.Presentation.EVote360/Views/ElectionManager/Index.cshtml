@using eVote360.Core.Application.ViewModels.Election
@model List<ElectionViewModel>
@{
    ViewData["Title"] = "Gestión de Elecciones";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var hasData = Model != null && Model.Any();
    var count = Model?.Count ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #e8f5e9; color: #2e7d32; padding: 12px; border-radius: 12px;">
            <i class="bi bi-calendar-event-fill" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Procesos Electorales</h1>
            <p class="page-header__subtitle">
                @count proceso@(count != 1 ? "s" : "") registrado@(count != 1 ? "s" : "") en el sistema
            </p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Summary" class="btn-filter-outline" style="border: 1px solid #1976d2; color: #1976d2;">
            <i class="bi bi-graph-up-arrow" aria-hidden="true"></i>
            <span>Resumen por Año</span>
        </a>
        <a asp-action="Create" class="btn-add">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            <span>Nueva Elección</span>
        </a>
    </div>
</div>

<div class="filters-bar">
    <div class="filters-bar__quick">
        <a asp-action="GetActive" class="btn-filter-outline btn-filter-outline--active">
            <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
            Solo Activas
        </a>
        <a asp-action="Index" class="btn-filter-outline">
            <i class="bi bi-list-ul" aria-hidden="true"></i>
            Todas
        </a>
    </div>
</div>

@if (hasData)
{
    <div class="data-table-wrap">
        <table class="data-table" aria-label="Lista de procesos electorales">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">
                        <i class="bi bi-type" aria-hidden="true"></i>Nombre de Elección
                    </th>
                    <th scope="col">
                        <i class="bi bi-calendar3" aria-hidden="true"></i>Fecha Programada
                    </th>
                    <th scope="col">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>Etapa
                    </th>
                    <th scope="col">
                        <i class="bi bi-toggle-on" aria-hidden="true"></i>Estado
                    </th>
                    <th scope="col" class="text-center">
                        <i class="bi bi-gear-fill" aria-hidden="true"></i>Acciones
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model!)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="data-table__name">@item.Name</td>
                        <td>@item.ElectionDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                var badgeClass = item.ElectionState.ToString() switch
                                {
                                    "Pendiente" => "bg-warning text-dark",
                                    "Activa" => "data-badge--active",
                                    "Finalizada" => "bg-secondary text-white",
                                    _ => "bg-light text-dark"
                                };
                            }
                            <span class="data-badge @badgeClass">
                                @item.ElectionState
                            </span>
                        </td>
                        <td>
                            <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                                <i class="bi @(item.State ? "bi-check-circle-fill" : "bi-x-circle-fill")" aria-hidden="true"></i>
                                @(item.State ? "Habilitada" : "Inactiva")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions justify-content-center">
                                <a asp-action="Edit" 
                                   asp-route-Id="@item.Id" 
                                   class="btn-table-action btn-table-action--edit" 
                                   title="Editar"
                                   aria-label="Editar @item.Name">
                                    <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                                </a>
                                <form asp-action="AlterState" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                            title="@(item.State ? "Finalizar" : "Activar")"
                                            aria-label="@(item.State ? "Finalizar" : "Activar") @item.Name">
                                        <i class="bi @(item.State ? "bi-toggle-on" : "bi-toggle-off")" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state" role="status">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-calendar-x"></i>
        </div>
        <h2 class="empty-state__title">No hay elecciones registradas</h2>
        <p class="empty-state__desc">
            Aún no se han configurado procesos electorales en el sistema.
        </p>
        <a asp-action="Create" class="btn-primary-outline">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            Programar Primera Elección
        </a>
    </div>
}
