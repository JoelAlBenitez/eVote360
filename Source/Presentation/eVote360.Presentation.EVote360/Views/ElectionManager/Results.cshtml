@{
    ViewData["Title"] = "Resumen Electoral por Año";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Notifications")

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #e3f2fd; color: #1976d2; padding: 12px; border-radius: 12px;">
            <i class="bi bi-bar-chart-line-fill" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Resumen Electoral</h1>
            <p class="page-header__subtitle">Consulta los resultados y métricas de las elecciones por año</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Volver a Elecciones</span>
    </a>
</div>

<div class="form-card" style="max-width: 600px; margin: 0 auto 2rem auto;">
    <form asp-action="Results" method="get" class="d-flex flex-column gap-3">
        
        <div class="form-field">
            <label class="form-label" for="year">Año Electoral</label>
            <div class="d-flex gap-2">
                <select name="year" id="year" class="form-input" required>
                    <option value="">Seleccione un año...</option>
                    @* Esto debería venir del ViewBag con los años que tienen elecciones *@
                    @for (int i = DateTime.Now.Year; i >= 2020; i--)
                    {
                        var isSelected = Context.Request.Query["year"] == i.ToString() ? "selected" : "";
                        <!option value="@i" @isSelected>@i</!option>
                    }
                </select>
                <button type="submit" class="btn-submit" style="white-space: nowrap;">
                    <i class="bi bi-search" aria-hidden="true"></i> Obtener Resumen
                </button>
            </div>
            <span class="form-hint">Selecciona el año para ver las elecciones correspondientes.</span>
        </div>
    </form>
</div>

@if (Context.Request.Query.ContainsKey("year"))
{
    @* Esta sección se mostrará cuando se implemente la vista parcial o los datos del recuento *@
    <div class="empty-state" role="status" style="margin-top: 2rem;">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-pie-chart-fill"></i>
        </div>
        <h2 class="empty-state__title">Módulo de Recuento en Construcción</h2>
        <p class="empty-state__desc">
            Los resultados para el año @Context.Request.Query["year"] se mostrarán aquí una vez que se integre el módulo de Votos y Participantes.
        </p>
    </div>
}
