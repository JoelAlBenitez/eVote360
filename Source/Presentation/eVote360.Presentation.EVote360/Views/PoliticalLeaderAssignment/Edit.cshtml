@using eVote360.Core.Application.ViewModels.PoliticalLeaderAssignment
@model LeaderAssignmentEditViewModel
@{
    ViewData["Title"] = "Modificar Asignación";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Notifications")

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #fff3e0; color: #f57c00; padding: 12px; border-radius: 12px;">
            <i class="bi bi-pencil-square" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Modificar Asignación</h1>
            <p class="page-header__subtitle">Actualiza la vinculación entre el dirigente y el partido</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Volver al listado</span>
    </a>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post" novalidate>
        @Html.AntiForgeryToken()
        
        <input type="hidden" asp-for="Id" />

        <div class="form-field">
            <label class="form-label" asp-for="Name">Nombre del Registro</label>
            <input asp-for="Name" 
                   class="form-input" 
                   placeholder="Ej. Asignación Juan Pérez a Partido X" 
                   autocomplete="off" />
            <span class="form-hint">Referencia interna de la asignación.</span>
            <span asp-validation-for="Name" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="PoliticalLeaderId">Dirigente Político</label>
            @* En edición, solemos mostrar el líder actual preseleccionado y bloquearlo o permitir cambiarlo si las reglas lo permiten. ViewBag.Leaders debe contener las opciones válidas. *@
            <select asp-for="PoliticalLeaderId" class="form-input" asp-items="ViewBag.Leaders">
                <option value="">-- Seleccione un Dirigente --</option>
            </select>
            <span asp-validation-for="PoliticalLeaderId" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="PoliticalPartyId">Partido Político</label>
            <select asp-for="PoliticalPartyId" class="form-input" asp-items="ViewBag.Parties">
                <option value="">-- Seleccione un Partido --</option>
            </select>
            <span asp-validation-for="PoliticalPartyId" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="PoliticalAssignmentDate">Fecha de Asignación</label>
            <input asp-for="PoliticalAssignmentDate" 
                   type="date" 
                   class="form-input" 
                   value="@Model.PoliticalAssignmentDate.ToString("yyyy-MM-dd")" />
            <span class="form-hint">Fecha en la que se oficializó la asignación.</span>
            <span asp-validation-for="PoliticalAssignmentDate" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="State">Estado Lógico</label>
            <div class="form-toggle">
                <label class="toggle-switch" title="Activar o desactivar asignación">
                    <input asp-for="State" type="checkbox" />
                    <span class="toggle-switch__slider"></span>
                </label>
                <span class="toggle-label">Asignación Vigente</span>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                Cancelar
            </a>
            <button type="submit" class="btn-submit">
                <i class="bi bi-floppy-fill" aria-hidden="true"></i>
                <span>Actualizar Asignación</span>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
