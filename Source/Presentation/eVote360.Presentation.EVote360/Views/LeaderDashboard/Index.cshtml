@model eVote360.Core.Application.ViewModels.LeaderDashboard.LeaderDashboardViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_LeaderLayout";
    ViewData["Title"] = "Panel del Dirigente";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
    <style>
        .admin-hero__bg {
            background: linear-gradient(135deg, #1f2937 0%, #374151 100%) !important;
        }
        .admin-hero__orb--1 { background: radial-gradient(circle at center, rgba(16, 185, 129, 0.15) 0%, transparent 70%) !important; }
        .admin-hero__orb--2 { background: radial-gradient(circle at center, rgba(59, 130, 246, 0.15) 0%, transparent 70%) !important; }
        .admin-hero__orb--3 { background: radial-gradient(circle at center, rgba(245, 158, 11, 0.15) 0%, transparent 70%) !important; }
    </style>
}



<div class="admin-hero">
    <div class="admin-hero__bg">
        <div class="admin-hero__orb admin-hero__orb--1"></div>
        <div class="admin-hero__orb admin-hero__orb--2"></div>
        <div class="admin-hero__orb admin-hero__orb--3"></div>
    </div>

    <div class="admin-hero__content">
        <div class="admin-hero__greeting">
            <div class="d-flex align-items-center gap-3 mb-2">
                @if (!string.IsNullOrEmpty(Model.PartyLogoUrl))
                {
                    <img src="@Model.PartyLogoUrl" style="height:70px; width:70px; object-fit: cover;" class="rounded-circle shadow-sm border border-2 border-white" alt="Logo de @Model.PartyName" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center bg-light text-dark rounded-circle shadow-sm border border-2 border-white" style="height:70px; width:70px; font-size: 2rem;">
                        <i class="bi bi-flag-fill"></i>
                    </div>
                }
                <div>
                    <span class="admin-hero__salute d-block text-white-50" style="font-size: 0.9rem;">Dirigente Político</span>
                    <h1 class="admin-hero__name mb-0" style="font-size: 1.8rem;">
                        @Model.PartyName
                    </h1>
                </div>
            </div>
        </div>
        <div class="admin-hero__meta mt-3">
            <span class="admin-hero__badge" style="background: rgba(255,255,255,0.1); color: #fff;">
                <i class="bi bi-tag-fill" aria-hidden="true"></i>
                @Model.PartyAcronym
            </span>
            <span class="admin-hero__date" id="adminHeroDate" aria-live="off"></span>
        </div>
    </div>

    <div class="admin-hero__emblem" aria-hidden="true">
        <div class="admin-hero__emblem-ring"></div>
        <i class="bi bi-diagram-3-fill"></i>
    </div>
</div>

<div class="admin-stats-grid" aria-label="Resumen del sistema">

    <div class="stat-card stat-card--citizens">
        <div class="stat-card__icon-wrap">
            <i class="bi bi-person-check-fill" aria-hidden="true"></i>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value" data-count="@Model.ActiveCandidatesCount">0</span>
            <span class="stat-card__label">Candidatos Activos</span>
        </div>
        <div class="stat-card__footer">
            <span class="stat-card__link" style="color: var(--stat-cz); pointer-events:none; gap:0;">
                En el padrón
            </span>
        </div>
        <div class="stat-card__glow" aria-hidden="true"></div>
    </div>

    <div class="stat-card stat-card--parties">
        <div class="stat-card__icon-wrap">
            <i class="bi bi-person-x-fill" aria-hidden="true"></i>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value" data-count="@Model.InactiveCandidatesCount">0</span>
            <span class="stat-card__label">Candidatos Inactivos</span>
        </div>
        <div class="stat-card__footer">
            <span class="stat-card__link" style="color: var(--stat-p); pointer-events:none; gap:0;">
                Pendientes de revisión
            </span>
        </div>
        <div class="stat-card__glow" aria-hidden="true"></div>
    </div>

    <div class="stat-card stat-card--elections">
        <div class="stat-card__icon-wrap">
            <i class="bi bi-diagram-3-fill" aria-hidden="true"></i>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value" data-count="@Model.ApprovedAlliancesCount">0</span>
            <span class="stat-card__label">Alianzas Aprobadas</span>
        </div>
        <div class="stat-card__footer">
            <span class="stat-card__link" style="color: var(--stat-el); pointer-events:none; gap:0;">
                Acuerdos vigentes
            </span>
        </div>
        <div class="stat-card__glow" aria-hidden="true"></div>
    </div>

    <div class="stat-card stat-card--candidates">
        <div class="stat-card__icon-wrap">
            <i class="bi bi-award-fill" aria-hidden="true"></i>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value" data-count="@Model.AssignedCandidatesToPositionsCount">0</span>
            <span class="stat-card__label">Asignaciones</span>
        </div>
        <div class="stat-card__footer">
            <span class="stat-card__link" style="color: var(--stat-cd); pointer-events:none; gap:0;">
                Candidatos en posiciones
            </span>
        </div>
        <div class="stat-card__glow" aria-hidden="true"></div>
    </div>

</div>

<div class="admin-quick-access">
    <h2 class="section-title">
        <i class="bi bi-lightning-fill" aria-hidden="true"></i>
        Acceso Rápido
    </h2>
    <div class="col-md-4">
        <a asp-controller="Candidates" asp-action="Index" class="quick-card quick-card--elections">
            <div class="quick-card__icon">
                <i class="bi bi-people-fill" aria-hidden="true"></i>
            </div>
            <div class="quick-card__body">
                <span class="quick-card__title">Mis Candidatos</span>
                <span class="quick-card__desc">Gestiona tus candidatos</span>
            </div>
            <i class="bi bi-arrow-right-circle quick-card__arrow" aria-hidden="true"></i>
        </a>
    </div>

        <a asp-controller="PoliticalAlliances" asp-action="Index" class="quick-card quick-card--positions">
            <div class="quick-card__icon">
                <i class="bi bi-diagram-3-fill" aria-hidden="true"></i>
            </div>
            <div class="quick-card__body">
                <span class="quick-card__title">Alianzas Políticas</span>
                <span class="quick-card__desc">Solicitudes y acuerdos</span>
            </div>
            <i class="bi bi-arrow-right-circle quick-card__arrow" aria-hidden="true"></i>
        </a>

        <a asp-controller="CandidateAssignment" asp-action="Index" class="quick-card quick-card--citizens">
            <div class="quick-card__icon">
                <i class="bi bi-person-check-fill" aria-hidden="true"></i>
            </div>
            <div class="quick-card__body">
                <span class="quick-card__title">Asignar Candidatos</span>
                <span class="quick-card__desc">A posiciones electivas</span>
            </div>
            <i class="bi bi-arrow-right-circle quick-card__arrow" aria-hidden="true"></i>
        </a>

    </div>
</div>

@section Scripts {
    <script src="~/js/admin-views.js" asp-append-version="true"></script>
}
