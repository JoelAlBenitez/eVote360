@using eVote360.Core.Application.ViewModels.Citizens
@model List<CitizensViewModel>
@{
    ViewData["Title"] = "Ciudadanos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var hasData = Model != null && Model.Any();
    var count   = Model?.Count ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/citizen-views.css" asp-append-version="true" />
}


<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon page-header__icon--citizens">
            <i class="bi bi-people-fill" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Ciudadanos</h1>
            <p class="page-header__subtitle">
                @count ciudadano@(count != 1 ? "s" : "") registrado@(count != 1 ? "s" : "")
            </p>
        </div>
    </div>
    <a asp-action="Create" class="btn-add">
        <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
        <span>Nuevo Ciudadano</span>
    </a>
</div>

<div class="filters-bar">
    <div class="search-field">
        <i class="bi bi-search search-field__icon" aria-hidden="true"></i>
        <input type="text"
               id="citizenSearch"
               class="search-field__input"
               placeholder="Buscar por nombre, cédula, correo..." />
    </div>
    <div class="filters-bar__quick">
        <a asp-action="GetActive" class="btn-filter-outline btn-filter-outline--active">
            <i class="bi bi-person-check-fill" aria-hidden="true"></i>
            Solo Activos
        </a>
        <a asp-action="Index" class="btn-filter-outline">
            <i class="bi bi-list-ul" aria-hidden="true"></i>
            Todos
        </a>
    </div>
</div>

@if (hasData)
{
    <div class="data-table-wrap d-none d-md-block">
        <table class="data-table" aria-label="Lista de ciudadanos">
            <thead>
                <tr>
                    <th scope="col">
                        <i class="bi bi-card-text" aria-hidden="true"></i>Identificación
                    </th>
                    <th scope="col">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>Nombre
                    </th>
                    <th scope="col">
                        <i class="bi bi-person-fill" aria-hidden="true"></i>Apellido
                    </th>
                    <th scope="col">
                        <i class="bi bi-envelope-fill" aria-hidden="true"></i>Correo
                    </th>
                    <th scope="col">
                        <i class="bi bi-toggle-on" aria-hidden="true"></i>Estado
                    </th>
                    <th scope="col">
                        <i class="bi bi-gear-fill" aria-hidden="true"></i>Acciones
                    </th>
                </tr>
            </thead>
            <tbody id="citizensTableBody">
                @foreach (var item in Model!)
                {
                    <tr>
                        <td class="data-table__name">@item.Identification</td>
                        <td>@item.Name</td>
                        <td>@item.LastName</td>
                        <td>
                            <span class="data-table__date">@item.Email</span>
                        </td>
                        <td>
                            <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                                <i class="bi @(item.State ? "bi-check-circle-fill" : "bi-x-circle-fill")" aria-hidden="true"></i>
                                @(item.State ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Edit"
                                   asp-route-Id="@item.Id"
                                   class="btn-table-action btn-table-action--edit"
                                   title="Editar ciudadano"
                                   aria-label="Editar @item.Name @item.LastName">
                                    <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                                </a>
                                <a asp-action="AlterState"
                                   asp-route-Id="@item.Id"
                                   class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                   title="@(item.State ? "Desactivar ciudadano" : "Activar ciudadano")"
                                   aria-label="@(item.State ? "Desactivar" : "Activar") @item.Name @item.LastName">
                                    <i class="bi @(item.State ? "bi-person-x-fill" : "bi-person-check-fill")" aria-hidden="true"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-wrap" id="paginationWrap" aria-label="Paginación"></div>
    </div>

    <div class="ep-cards d-md-none" id="citizenCards" aria-label="Lista de ciudadanos">
        @foreach (var item in Model!)
        {
            <article class="ep-card">
                <div class="ep-card__header">
                    <span class="ep-card__name">@item.Name @item.LastName</span>
                    <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                        @(item.State ? "Activo" : "Inactivo")
                    </span>
                </div>
                <div class="ep-card__meta">
                    <i class="bi bi-card-text" aria-hidden="true"></i>
                    @item.Identification
                </div>
                <div class="ep-card__meta">
                    <i class="bi bi-envelope-fill" aria-hidden="true"></i>
                    @item.Email
                </div>
                <div class="ep-card__footer">
                    <a asp-action="Edit"
                       asp-route-Id="@item.Id"
                       class="btn-table-action btn-table-action--edit"
                       title="Editar"
                       aria-label="Editar @item.Name @item.LastName">
                        <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                    </a>
                    <a asp-action="AlterState"
                       asp-route-Id="@item.Id"
                       class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                       title="@(item.State ? "Desactivar" : "Activar")"
                       aria-label="@(item.State ? "Desactivar" : "Activar") @item.Name @item.LastName">
                        <i class="bi @(item.State ? "bi-person-x-fill" : "bi-person-check-fill")" aria-hidden="true"></i>
                    </a>
                </div>
            </article>
        }
        <div class="pagination-wrap" id="paginationWrapMobile" aria-label="Paginación móvil"></div>
    </div>
}
else
{
    <div class="empty-state" role="status">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-people"></i>
        </div>
        <h2 class="empty-state__title">Sin ciudadanos registrados</h2>
        <p class="empty-state__desc">
            Aún no se han registrado ciudadanos en el padrón electoral.
        </p>
        <a asp-action="Create" class="btn-primary-outline">
            <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
            Registrar Ciudadano
        </a>
    </div>
}

@section Scripts {
    <script src="~/js/admin-views.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            window.initTablePagination('citizensTableBody', 'paginationWrap', 10);
            window.initCardPagination('citizenCards', 'paginationWrapMobile', 5, '.ep-card');
            window.initTableSearch('citizenSearch', 'citizensTableBody', 'paginationWrap', 'citizenCards', '.ep-card', 'paginationWrapMobile');
        });
    </script>
}
