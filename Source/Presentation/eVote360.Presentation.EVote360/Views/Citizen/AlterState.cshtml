@using eVote360.Core.Application.ViewModels.Citizens
@model CitizensViewModelAlterState
@{
    ViewData["Title"] = "Cambiar Estado";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/citizen-views.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Notifications")

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon page-header__icon--citizens">
            <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Cambiar Estado</h1>
            <p class="page-header__subtitle">Confirmación de cambio de estado del ciudadano</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Volver</span>
    </a>
</div>

<div class="alter-card">
    <div class="alter-card__icon-wrap">
        <div class="alter-card__icon">
            <i class="bi bi-person-exclamation" aria-hidden="true"></i>
        </div>
    </div>
    <div class="alter-card__body">
        <h2 class="alter-card__title">¿Deseas cambiar el estado de este ciudadano?</h2>
        <span class="alter-card__name">
            <i class="bi bi-card-text" aria-hidden="true"></i>
            @Model.Identification
        </span>
        <p class="alter-card__desc">
            Esta acción alternará el estado actual del ciudadano entre activo e inactivo.
            Puedes revertirla en cualquier momento.
        </p>
    </div>
    <div class="alter-card__footer">
        <form asp-action="AlterState" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <button type="submit" class="btn-confirm">
                <i class="bi bi-check-lg" aria-hidden="true"></i>
                Confirmar Cambio
            </button>
        </form>
        <a asp-action="Index" class="btn-cancel">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            Cancelar
        </a>
    </div>
</div>
