@using eVote360.Core.Application.ViewModels.Citizens
@model CitizensViewModelCreate
@{
    ViewData["Title"] = "Registrar Ciudadano";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/citizen-views.css" asp-append-version="true" />
}


<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon page-header__icon--citizens">
            <i class="bi bi-person-plus-fill" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Registrar Ciudadano</h1>
            <p class="page-header__subtitle">Completa el formulario para registrar un nuevo ciudadano</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Volver</span>
    </a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label class="form-label" asp-for="Identification">Número de Cédula</label>
            <input asp-for="Identification"
                   class="form-input"
                   type="text"
                   placeholder="00000000000"
                   maxlength="11"
                   autocomplete="off" />
            <span class="form-hint">Exactamente 11 dígitos sin guiones.</span>
            <span asp-validation-for="Identification" class="form-error"></span>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label class="form-label" asp-for="Name">Nombre</label>
                <input asp-for="Name"
                       class="form-input"
                       type="text"
                       placeholder="Ej. Juan"
                       autocomplete="off" />
                <span asp-validation-for="Name" class="form-error"></span>
            </div>
            <div class="form-field">
                <label class="form-label" asp-for="LastName">Apellido</label>
                <input asp-for="LastName"
                       class="form-input"
                       type="text"
                       placeholder="Ej. Pérez"
                       autocomplete="off" />
                <span asp-validation-for="LastName" class="form-error"></span>
            </div>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="Email">Correo Electrónico</label>
            <input asp-for="Email"
                   class="form-input"
                   type="email"
                   placeholder="ciudadano@correo.com"
                   autocomplete="off" />
            <span asp-validation-for="Email" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="State">Estado inicial</label>
            <div class="form-toggle">
                <label class="toggle-switch" title="Activar o desactivar">
                    <input asp-for="State" type="checkbox" />
                    <span class="toggle-switch__slider"></span>
                </label>
                <span class="toggle-label">Activo al registrar</span>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                Cancelar
            </a>
            <button type="submit" class="btn-submit">
                <i class="bi bi-person-check-fill" aria-hidden="true"></i>
                Registrar Ciudadano
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
