@model eVote360.Core.Application.ViewModels.Login.LoginViewModel

@{
    ViewData["Title"] = "Acceder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <img src="~/logo/logo.png" alt="eVote360" height="50" class="mb-3" />
                    <h4 class="fw-bold text-primary">Iniciar Sesión</h4>
                    <p class="text-muted small">Accede al panel de administración</p>
                </div>

                <partial name="_Notifications" />

                <form asp-controller="Account" asp-action="LogIn" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="UserName" class="form-control" placeholder="Nombre de usuario" autocomplete="username" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Contraseña" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold rounded-pill">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Acceder
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
