@model dynamic // Usando dynamic para soportar PoliticalPartyViewModelCreate y PoliticalPartyViewModelEdit
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    bool isEdit = Model != null && Model.GetType().GetProperty("Id") != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "Editar Partido Político" : "Nuevo Partido Político";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<partial name="_Notifications" />

<div class="container mt-4 admin_view">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex align-items-center">
                    <i class="bi @(isEdit ? "bi-pencil-square" : "bi-plus-circle") me-2 fs-5"></i>
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    
                    <form method="post" asp-action="@(isEdit ? "Edit" : "Create")" enctype="multipart/form-data">
                        
                        @if (isEdit)
                        {
                            <input type="hidden" name="Id" value="@Model.Id" />
                            // Ocultos para mantener el estado si tu controller lo requiere en el post, ajusta según necesidad
                            <input type="hidden" name="State" value="@Model.State" />
                            @if(Model.GetType().GetProperty("PoliticalPartyLogo") != null)
                            {
                                <input type="hidden" name="PoliticalPartyLogo" value="@Model.PoliticalPartyLogo" />
                            }
                        }

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label for="PoliticalPartyAcronym" class="form-label fw-bold">Acrónimo</label>
                                <input type="text" id="PoliticalPartyAcronym" name="PoliticalPartyAcronym" value="@(Model?.PoliticalPartyAcronym)" class="form-control" placeholder="Ej. PRM" required />
                                <span class="text-danger field-validation-valid" data-valmsg-for="PoliticalPartyAcronym" data-valmsg-replace="true"></span>
                            </div>

                            <div class="col-md-8 mb-3">
                                <label for="Name" class="form-label fw-bold">Nombre del Partido</label>
                                <input type="text" id="Name" name="Name" value="@(Model?.Name)" class="form-control" placeholder="Nombre completo" required />
                                <span class="text-danger field-validation-valid" data-valmsg-for="Name" data-valmsg-replace="true"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="PoliticalPartyDescription" class="form-label fw-bold">Descripción / Ideología</label>
                            <textarea id="PoliticalPartyDescription" name="PoliticalPartyDescription" class="form-control" rows="3" placeholder="Breve descripción del partido...">@(Model?.PoliticalPartyDescription)</textarea>
                            <span class="text-danger field-validation-valid" data-valmsg-for="PoliticalPartyDescription" data-valmsg-replace="true"></span>
                        </div>

                        <div class="mb-4">
                            <label for="LogoFile" class="form-label fw-bold">Logo del Partido</label>
                            @if (isEdit && Model.GetType().GetProperty("PoliticalPartyLogo") != null && !string.IsNullOrEmpty(Model.PoliticalPartyLogo))
                            {
                                <div class="mb-2">
                                    <img src="~/img/parties/@Model.PoliticalPartyLogo" alt="Logo Actual" class="img-thumbnail" style="height: 80px;" />
                                    <small class="text-muted d-block mt-1">Logo actual. Seleccione una nueva imagen para cambiarlo.</small>
                                </div>
                            }
                            <input type="file" id="LogoFile" name="LogoFile" class="form-control" accept="image/*" @(isEdit ? "" : "required") />
                            <div class="form-text">Formatos permitidos: JPG, PNG, GIF. Tamaño máximo recomendado: 2MB.</div>
                            <span class="text-danger field-validation-valid" data-valmsg-for="LogoFile" data-valmsg-replace="true"></span>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Volver al Listado
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-save"></i> @(isEdit ? "Actualizar Partido" : "Guardar Partido")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
