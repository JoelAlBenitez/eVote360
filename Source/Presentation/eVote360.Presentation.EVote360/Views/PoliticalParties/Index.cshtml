@model IEnumerable<eVote360.Core.Application.ViewModels.PoliticalParty.PoliticalPartyViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Partidos Políticos";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var hasData = Model != null && Model.Any();
    var count = Model?.Count() ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}


<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon" style="background-color: #fce4ec; color: #c62828; padding: 12px; border-radius: 12px;">
            <i class="bi bi-flag-fill" style="font-size: 1.5rem;" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Partidos Políticos</h1>
            <p class="page-header__subtitle">
                @count partido@(count != 1 ? "s" : "") registrado@(count != 1 ? "s" : "")
            </p>
        </div>
    </div>
    <a asp-action="Create" class="btn-add">
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        <span>Nuevo Partido</span>
    </a>
</div>

@if (hasData)
{
    <div class="data-table-wrap d-none d-md-block">
        <table class="data-table" aria-label="Lista de partidos políticos">
            <thead>
                <tr>
                    <th scope="col">Logo</th>
                    <th scope="col">
                        <i class="bi bi-card-text" aria-hidden="true"></i>Acrónimo
                    </th>
                    <th scope="col">
                        <i class="bi bi-card-heading" aria-hidden="true"></i>Nombre
                    </th>
                    <th scope="col">
                        <i class="bi bi-text-paragraph" aria-hidden="true"></i>Descripción
                    </th>
                    <th scope="col">
                        <i class="bi bi-toggle-on" aria-hidden="true"></i>Estado
                    </th>
                    <th scope="col" class="text-center">
                        <i class="bi bi-gear-fill" aria-hidden="true"></i>Acciones
                    </th>
                </tr>
            </thead>
            <tbody id="partiesTableBody">
                @foreach (var item in Model!)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.PoliticalPartyLogo))
                            {
                                <img src="@item.PoliticalPartyLogo" alt="Logo @item.PoliticalPartyAcronym"
                                     style="width:48px;height:48px;object-fit:cover;border-radius:50%;" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;border-radius:50%;background:#e0e0e0;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-flag-fill text-secondary"></i>
                                </div>
                            }
                        </td>
                        <td class="data-table__name">@item.PoliticalPartyAcronym</td>
                        <td>@item.Name</td>
                        <td>
                            <span title="@item.PoliticalPartyDescription">
                                @(item.PoliticalPartyDescription?.Length > 60
                                    ? item.PoliticalPartyDescription.Substring(0, 60) + "…"
                                    : item.PoliticalPartyDescription)
                            </span>
                        </td>
                        <td>
                            <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                                <i class="bi @(item.State ? "bi-check-circle-fill" : "bi-x-circle-fill")" aria-hidden="true"></i>
                                @(item.State ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions justify-content-center">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn-table-action btn-table-action--edit"
                                   title="Editar"
                                   aria-label="Editar @item.Name">
                                    <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                                </a>
                                <form asp-action="AlterState" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                            title="@(item.State ? "Desactivar" : "Activar")"
                                            aria-label="@(item.State ? "Desactivar" : "Activar") @item.Name"
                                            onclick="return confirm('¿Está seguro que desea @(item.State ? "desactivar" : "activar") este partido?');">
                                        <i class="bi @(item.State ? "bi-slash-circle" : "bi-check-circle")" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-wrap" id="paginationWrap" aria-label="Paginación"></div>
    </div>

    <div class="ep-cards d-md-none" id="partyCards" aria-label="Lista de partidos">
        @foreach (var item in Model!)
        {
            <article class="ep-card">
                <div class="ep-card__header">
                    <span class="ep-card__name">@item.PoliticalPartyAcronym — @item.Name</span>
                    <span class="data-badge @(item.State ? "data-badge--active" : "data-badge--inactive")">
                        @(item.State ? "Activo" : "Inactivo")
                    </span>
                </div>
                <p class="ep-card__desc">@item.PoliticalPartyDescription</p>
                <div class="ep-card__footer">
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn-table-action btn-table-action--edit"
                       title="Editar"
                       aria-label="Editar @item.Name">
                        <i class="bi bi-pencil-fill" aria-hidden="true"></i>
                    </a>
                    <form asp-action="AlterState" asp-route-id="@item.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn-table-action @(item.State ? "btn-table-action--deactivate" : "btn-table-action--activate")"
                                title="@(item.State ? "Desactivar" : "Activar")"
                                onclick="return confirm('¿Desactivar/Activar este partido?');">
                            <i class="bi @(item.State ? "bi-slash-circle" : "bi-check-circle")" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </article>
        }
        <div class="pagination-wrap" id="paginationWrapMobile" aria-label="Paginación móvil"></div>
    </div>
}
else
{
    <div class="empty-state" role="status">
        <div class="empty-state__icon" aria-hidden="true">
            <i class="bi bi-flag"></i>
        </div>
        <h2 class="empty-state__title">Sin partidos registrados</h2>
        <p class="empty-state__desc">
            Aún no se han registrado partidos políticos en el sistema.
        </p>
        <a asp-action="Create" class="btn-primary-outline">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            Registrar Partido
        </a>
    </div>
}

@section Scripts {
    <script src="~/js/admin-views.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            window.initTablePagination('partiesTableBody', 'paginationWrap', 10);
            window.initCardPagination('partyCards', 'paginationWrapMobile', 5, '.ep-card');
        });
    </script>
}
