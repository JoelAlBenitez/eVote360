@model IEnumerable<eVote360.Core.Application.ViewModels.PoliticalParty.PoliticalPartyViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Partidos Políticos";
    // Asumiendo que el layout principal es el admin layout basado en el análisis anterior
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

<partial name="_Notifications" />

<div class="container mt-4 admin_view">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Partidos Políticos</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Partido</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Logo</th>
                            <th>Acrónimo</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.PoliticalPartyLogo))
                                        {
                                            <img src="~/img/parties/@item.PoliticalPartyLogo" alt="Logo de @item.PoliticalPartyAcronym" class="rounded-circle shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center bg-secondary text-white rounded-circle" style="width: 50px; height: 50px;">
                                                <i class="bi bi-flag-fill"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold">@item.PoliticalPartyAcronym</td>
                                    <td>@item.PoliticalPartyDescription</td>
                                    <td>
                                        @if (item.State)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Editar">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>
                                            <form asp-action="AlterState" asp-route-id="@item.Id" method="post" class="d-inline ms-1">
                                                <button type="submit" class="btn btn-sm @(item.State ? "btn-danger" : "btn-success")" 
                                                        onclick="return confirm('¿Está seguro que desea @(item.State ? "desactivar" : "activar") este partido?');">
                                                    <i class="bi @(item.State ? "bi-slash-circle" : "bi-check-circle")"></i> @(item.State ? "Desactivar" : "Activar")
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    No hay partidos políticos registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
