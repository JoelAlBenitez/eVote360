@using eVote360.Core.Application.ViewModels.ElectivePositions
@model ElectivePosictionsViewModelCreate
@{
    ViewData["Title"] = "Nuevo Puesto Electivo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-views.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Notifications")

<div class="page-header">
    <div class="page-header__left">
        <div class="page-header__icon page-header__icon--positions">
            <i class="bi bi-award-fill" aria-hidden="true"></i>
        </div>
        <div>
            <h1 class="page-header__title">Nuevo Puesto Electivo</h1>
            <p class="page-header__subtitle">Completa el formulario para registrar un nuevo puesto</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Volver</span>
    </a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-field">
            <label class="form-label" asp-for="Name">Nombre</label>
            <input asp-for="Name"
                   class="form-input"
                   type="text"
                   placeholder="Ej. Presidente de la República"
                   autocomplete="off" />
            <span class="form-hint">Entre 5 y 30 caracteres.</span>
            <span asp-validation-for="Name" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="Description">Descripción</label>
            <textarea asp-for="Description"
                      class="form-textarea"
                      placeholder="Describe brevemente este puesto electivo..."
                      maxlength="100"></textarea>
            <span class="form-hint">Máximo 100 caracteres.</span>
            <span asp-validation-for="Description" class="form-error"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="State">Estado inicial</label>
            <div class="form-toggle">
                <label class="toggle-switch" title="Activar o desactivar">
                    <input asp-for="State" type="checkbox" />
                    <span class="toggle-switch__slider"></span>
                </label>
                <span class="toggle-label">Activo al crear</span>
            </div>
        </div>

        <div class="form-footer">
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                Cancelar
            </a>
            <button type="submit" class="btn-submit">
                <i class="bi bi-floppy-fill" aria-hidden="true"></i>
                Guardar Puesto
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
